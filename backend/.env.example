# backend/.env.example
APP_NAME=CollabVerse
ENV=development

# GitHub (get your own token)
GITHUB_TOKEN=your-github-token-here

# Django/Flask secret (change in production)
SECRET_KEY=dev-secret-change-later

# JWT Settings (change in production)
JWT_SECRET_KEY=your-super-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database (update with your credentials)
DATABASE_URL=postgresql://user:password@localhost/dbname